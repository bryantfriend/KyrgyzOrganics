rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userCompanyId() {
      return userProfile().data.companyId;
    }

    function userRole() {
      return userProfile().data.role;
    }

    function isLegacyAdmin() {
      return isSignedIn() && !hasUserProfile();
    }

    function isSuperAdmin() {
      return hasUserProfile() && userRole() == "superadmin";
    }

    function canReadAnyCompany() {
      return isLegacyAdmin() || isSuperAdmin();
    }

    function canReadCompanyData() {
      return canReadAnyCompany() || (hasUserProfile() && resource.data.companyId == userCompanyId());
    }

    function canWriteCompanyData() {
      return canReadAnyCompany() || (hasUserProfile() && request.resource.data.companyId == userCompanyId());
    }

    function canDeleteCompanyData() {
      return canReadAnyCompany() || (hasUserProfile() && resource.data.companyId == userCompanyId());
    }

    function isActive() {
      return resource.data.active == true;
    }

    match /products/{productId} {
      allow read: if isActive();
      allow read: if isSignedIn() && canReadCompanyData();
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /categories/{categoryId} {
      allow read: if isActive();
      allow read: if isSignedIn() && canReadCompanyData();
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /banners/{bannerId} {
      allow read: if isActive();
      allow read: if isSignedIn() && canReadCompanyData();
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /payment_methods/{methodId} {
      allow read: if isActive();
      allow read: if isSignedIn() && canReadCompanyData();
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /inventory/{dateId} {
      allow read: if true;
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /pages/{pageId} {
      allow read: if true;
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /shop_settings/{docId} {
      allow read: if true;
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /campaigns/{campaignId} {
      allow read: if true;
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /campaign_events/{eventId} {
      allow create: if
        request.resource.data.companyId is string &&
        request.resource.data.campaignId is string &&
        request.resource.data.sessionId is string &&
        request.resource.data.timestamp != null &&
        request.resource.data.actionType is string;

      allow read: if isSignedIn() && canReadCompanyData();
      allow update, delete: if false;
    }

    match /inventory_templates/{templateId} {
      allow read: if isSignedIn() && canReadCompanyData();
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && canReadCompanyData();
      allow create, update: if isSignedIn() && canWriteCompanyData();
      allow delete: if isSignedIn() && canDeleteCompanyData();
    }

    match /companies/{companyId} {
      allow read: if isSignedIn() && (canReadAnyCompany() || (hasUserProfile() && companyId == userCompanyId()));
      allow write: if isSignedIn() && canReadAnyCompany();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || canReadAnyCompany());
      allow write: if isSignedIn() && canReadAnyCompany();
    }

    match /audit_logs/{logId} {
      allow read: if isSignedIn() && canReadCompanyData();
      allow create: if isSignedIn() && canWriteCompanyData();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
