{
    "functions": {
        "source": "functions",
        "runtime": "nodejs22"
    },
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "public": ".",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/:store/admin/admin.html",
                "destination": "/admin/admin.html"
            }
        ]
    }
}
